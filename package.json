    "mongoose": "^9.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6",
    "zod-to-mongoose": "^1.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
