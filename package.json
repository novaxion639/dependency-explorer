{
  "name": "dependency-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @dependency-explorer/web dev",
    "build": "pnpm --filter @dependency-explorer/web build",
    "preview": "pnpm --filter @dependency-explorer/web preview",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "discover": "pnpm --filter @dependency-explorer/discovery discover",
    "discover:apply": "pnpm --filter @dependency-explorer/discovery discover:apply",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "typescript": "~5.7.2"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
